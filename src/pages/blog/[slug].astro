---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAllBlogPosts, getBlogPostById } from '../../data/cms-helpers';
import type { ContentBlock } from '../../data/cms-helpers';

export async function getStaticPaths() {
  const posts = getAllBlogPosts();
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;

// FIX (Task 2): Helper to resolve internal reference links to actual URLs.
// Looks up the referenced post by ID, returns its blog URL.
// Returns undefined if the post doesn't exist or was deleted.
function resolveReference(refId: string): string | undefined {
  const referenced = getBlogPostById(refId);
  if (!referenced || referenced._deleted) return undefined;
  return `/blog/${referenced.slug}`;
}
---

<BaseLayout title={post.seo?.title ?? post.title ?? 'Blog Post'} description={post.seo?.description}>
  {/* FIX (Task 3): JSON-LD structured data for SEO */}
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": post.title,
    "author": {
      "@type": "Person",
      "name": post.author,
    },
    "datePublished": post.publishedAt,
    "description": post.seo?.description ?? post.excerpt,
    "publisher": {
      "@type": "Organization",
      "name": "Boldin",
    },
  })} />

  <article>
    <header>
      <span class="category">{post.category}</span>
      <h1>{post.title}</h1>
      <div class="meta">
        <span>By {post.author}</span>
        <span>&middot;</span>
        <time datetime={post.publishedAt}>
          {post.publishedAt && new Date(post.publishedAt).toLocaleDateString('en-US', {
            year: 'numeric', month: 'long', day: 'numeric'
          })}
        </time>
      </div>
    </header>

    <div class="body">
      {post.body?.map((block: ContentBlock) => {
        if (block.type === 'paragraph') {
          return <p>{block.text}</p>;
        }
        if (block.type === 'heading') {
          const Tag = `h${block.level}` as any;
          return <Tag>{block.text}</Tag>;
        }
        if (block.type === 'link') {
          // FIX (Task 2): Resolve internal references to real URLs.
          // For external links, use the href directly.
          // For internal references, look up the post by ID and build the URL.
          // If the referenced post is deleted/missing, render plain text instead of a broken link.
          let href: string | undefined;
          if (block.external) {
            href = block.href;
          } else if (block.reference) {
            href = resolveReference(block.reference);
          }

          // FIX (Task 2): Graceful handling — if reference is missing/deleted,
          // render the text without a link instead of a broken <a> tag.
          if (!href) {
            return <p><span>{block.text}</span></p>;
          }

          return <p><a href={href} target={block.external ? '_blank' : undefined} rel={block.external ? 'noopener noreferrer' : undefined}>{block.text}</a></p>;
        }
      })}
    </div>

    <footer class="post-footer">
      <a href="/blog">&larr; Back to all posts</a>
    </footer>
  </article>
</BaseLayout>

<style>
  header { margin-bottom: 2rem; }
  .category {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    color: #2563eb;
    letter-spacing: 0.05em;
  }
  h1 { font-size: 2rem; margin: 0.5rem 0; }
  .meta { font-size: 0.9rem; color: #6b7280; display: flex; gap: 0.5rem; }
  .body { margin-top: 1.5rem; }
  .body p { margin-bottom: 1rem; }
  .body h2 { margin: 2rem 0 1rem; font-size: 1.5rem; }
  .body a { color: #2563eb; text-decoration: underline; }
  .post-footer { margin-top: 3rem; padding-top: 1.5rem; border-top: 1px solid #e5e7eb; }
</style>

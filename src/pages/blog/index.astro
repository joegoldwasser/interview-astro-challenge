---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CategoryFilter from '../../components/CategoryFilter.tsx';
import SearchFilter from '../../components/SearchFilter.tsx';
import FeaturedPosts from '../../components/FeaturedPosts.tsx';
import { getPublishedPostSummaries } from '../../data/cms-helpers';

const posts = getPublishedPostSummaries();
---

<BaseLayout title="Blog | Boldin" description="Retirement planning insights and guides.">
  <h1>Blog</h1>

  <section class="task-section">
    <h2>Task 1: Category Filter</h2>
    <CategoryFilter client:load posts={posts} />
  </section>

  <section class="task-section">
    <h2>Task 2: Search</h2>
    <SearchFilter client:load posts={posts} />
  </section>

  <section class="task-section">
    <h2>Task 3: Featured Posts</h2>
    <FeaturedPosts client:load />
  </section>
</BaseLayout>

<style>
  h1 { margin-bottom: 2rem; }
  h2 { font-size: 1.25rem; color: #6b7280; margin-bottom: 1rem; border-bottom: 1px solid #e5e7eb; padding-bottom: 0.5rem; }
  .task-section { margin-bottom: 3rem; }
</style>

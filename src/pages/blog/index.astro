---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogPostCard from '../../components/BlogPostCard.astro';
import SearchFilter from '../../components/SearchFilter.tsx';
import { getAllBlogPosts, getPublishedPostSummaries } from '../../data/cms-helpers';

const posts = getAllBlogPosts().filter((p) => !p._deleted && p.title);
const postSummaries = getPublishedPostSummaries();
---

<BaseLayout title="Blog | Boldin" description="Retirement planning insights and guides.">
  <h1>Blog</h1>

  <SearchFilter client:load posts={postSummaries} />

  <section>
    {posts.map((post) => (
      <BlogPostCard
        title={post.title}
        slug={post.slug}
        excerpt={post.excerpt}
        author={post.author}
        publishedAt={post.publishedAt}
        category={post.category}
      />
    ))}
  </section>
</BaseLayout>

<style>
  h1 { margin-bottom: 2rem; }
</style>

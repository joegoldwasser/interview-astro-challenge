---
/**
 * A card that displays a blog post summary.
 * Used on the blog index page.
 */
interface Props {
  title: string;
  slug: string;
  excerpt: string;
  author: string;
  publishedAt: string;
  category: string;
}

const { title, slug, excerpt, author, publishedAt, category } = Astro.props;
---

<article class="post-card">
  <span class="category">{category}</span>
  <h2><a href={`/blog/${slug}`}>{title}</a></h2>
  <p class="excerpt">{excerpt}</p>
  <div class="meta">
    <span>{author}</span>
    <span>&middot;</span>
    <time datetime={publishedAt}>
      {new Date(publishedAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
    </time>
  </div>
</article>

<style>
  .post-card {
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    padding: 1.5rem;
    margin-bottom: 1.5rem;
    transition: box-shadow 0.15s;
  }
  .post-card:hover {
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
  }
  .category {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    color: #2563eb;
    letter-spacing: 0.05em;
  }
  h2 { margin: 0.5rem 0; font-size: 1.25rem; }
  h2 a { color: #1a1a1a; }
  h2 a:hover { color: #2563eb; }
  .excerpt { color: #4b5563; margin: 0.5rem 0; }
  .meta { font-size: 0.85rem; color: #6b7280; display: flex; gap: 0.5rem; }
</style>
